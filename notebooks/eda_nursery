   "source": [
    "print(\"=== RELATION ENTRE CHAQUE VARIABLE ET LA CIBLE (Chi-2) ===\\n\")\n",
    "results = []\n",
    "for col in df.columns[:-1]:\n",
    "    ct = pd.crosstab(df[col], df['class'])\n",
    "    chi2, p, dof, _ = chi2_contingency(ct)\n",
    "    results.append({\n",
    "        'Variable': col,\n",
    "        'Chi2': round(chi2, 2),\n",
    "        'p-value': round(p, 6),\n",
    "        'Significatif (p<0.05)': '✅ OUI' if p < 0.05 else '❌ NON'\n",
    "    })\n",
    "\n",
    "chi2_df = pd.DataFrame(results).sort_values('Chi2', ascending=False)\n",
    "print(chi2_df.to_string(index=False))"
   ]
