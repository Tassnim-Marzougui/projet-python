    "from scipy.stats import chi2_contingency\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "def cramers_v(x, y):\n",
    "    ct = pd.crosstab(x, y)\n",
    "    chi2, _, _, _ = chi2_contingency(ct)\n",
    "    n = ct.sum().sum()\n",
    "    r, k = ct.shape\n",
    "    return np.sqrt(chi2 / (n * (min(r, k) - 1)))\n",
    "\n",
    "print(\"=== CRAMER'S V (Force d'association avec 'class') ===\\n\")\n",
    "cramer_results = []\n",
    "for col in features:\n",
    "    v = cramers_v(df[col], df['class'])\n",
    "    cramer_results.append({'Variable': col, \"Cramer's V\": round(v, 4)})\n",
    "\n",
    "cramer_df = pd.DataFrame(cramer_results).sort_values(\"Cramer's V\", ascending=False)\n",
    "\n",
    "# Graphique\n",
    "plt.figure(figsize=(10, 5))\n",
    "colors_bar = ['#2ecc71' if v > 0.5 else '#f39c12' if v > 0.3 else '#e74c3c'\n",
    "              for v in cramer_df[\"Cramer's V\"]]\n",
    "bars = plt.bar(cramer_df['Variable'], cramer_df[\"Cramer's V\"],\n",
    "               color=colors_bar, edgecolor='white', linewidth=1.2)\n",
    "\n",
